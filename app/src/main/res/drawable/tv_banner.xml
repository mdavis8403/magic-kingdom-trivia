<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/banner_blue"
                android:startColor="@color/banner_navy" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:bottom="20dp"
        android:left="24dp"
        android:right="24dp"
        android:top="20dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="@color/banner_gold" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="36dp"
        android:gravity="center_vertical|start"
        android:left="56dp"
        android:right="420dp"
        android:top="36dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#00FFFFFF"
                android:startColor="#1FFFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>

